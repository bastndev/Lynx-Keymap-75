{
  "name": "lynx-keymap-75",
  "displayName": "Lynx Keymap 75% Keyboard",
  "description": "Available now: VSCode • Cursor • Windsurf • Trae.ai • Kiro & Antigravity... 雨",
  "version": "2.0.0",
  "publisher": "bastndev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Keymaps","Other"],
  "keywords": [
    "keybindings",
    "keymap",
    "75% keyboard",
    "shortcuts",
    "productivity",
    "windows",
    "linux",
    "macos",
    "2025"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "homepage": "https://github.com/bastndev/Lynx-Keymap-75#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bastndev/Lynx-Keymap-75"
  },
  "bugs": {
    "url": "https://github.com/bastndev/Lynx-Keymap-75/issues"
  },
  "author": {
    "name": "Gohit Bastian", 
    "email": "hello@gohit.xyz",
    "url": "https://www.gohit.xyz/me"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/gohit.xyz"
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun esbuild.js",
    "watch": "bun esbuild.js --watch",
    "package": "bun esbuild.js --production",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  
  "activationEvents": [
    "onStartupFinished",

    "onCommand:lynx-keymap.generateAICommit",
    "onCommand:lynx-keymap.openAndCloseAIChat",
    "onCommand:lynx-keymap.createNewAISession",
    "onCommand:lynx-keymap.showAIHistory",
    "onCommand:lynx-keymap.selectModels",
    "onCommand:lynx-keymap.toggleTerminalLeft",

    "onCommand:lynx-keymap.toggleAgentMode",
    "onCommand:lynx-keymap.checkF1QuickSwitch",
    "onCommand:lynx-keymap.checkCompareCode"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "keybindings": [
      {
        "key"    : "ctrl+1",
        "mac"    : "cmd+1",
        "command": "workbench.view.explorer"
      },{
        "key"    : "ctrl+2",
        "mac"    : "cmd+2",
        "command": "workbench.view.scm"
      },{
        "key"    : "ctrl+3",
        "mac"    : "cmd+3",
        "command": "workbench.view.extensions"
      },{
        "key"    : "ctrl+4",
        "mac"    : "cmd+4",
        "command": "lynx-keymap.checkF1QuickSwitch"
      },{
        "key"    : "shift+alt+\\",
        "mac"    : "shift+alt+\\",
        "command": "-Compare Code"
      },{
        "key"    : "shift+alt+\\",
        "mac"    : "shift+alt+\\",
        "command": "lynx-keymap.checkCompareCode"
      },
      

      {
        "key"    : "alt+x",
        "mac"    : "alt+x",
        "command": "explorer.newFile"
      },{
        "key"    : "alt+c",
        "mac"    : "alt+c",
        "command": "explorer.newFolder"
      },{
        "key"    : "ctrl+capslock",
        "mac"    : "cmd+capslock",
        "command": "workbench.action.toggleSidebarVisibility"
      },


      {
        "key"    : "alt+1",
        "mac"    : "alt+1",
        "command": "git.stageAll",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+2",
        "mac"    : "alt+2",
        "command": "lynx-keymap.generateAICommit",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+3",
        "mac"    : "alt+3",
        "command": "git.unstageAll",
        "when"   : "scmProvider == git"
      },{
        "key"    : "alt+4",
        "mac"    : "alt+4",
        "command": "git.pull",
        "when"   : "scmProvider == git"
      },

      {
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "git.commit",
        "when"   : "scmProvider == git"
      },{
        "key"    : "ctrl+alt+enter",
        "mac"    : "cmd+alt+return",
        "command": "git.push",
        "when"   : "scmProvider == git"
      },











      {
        "key"    : "alt+q",
        "mac"    : "alt+q",
        "command": "workbench.action.terminal.new"
      },{
        "key"    : "ctrl+q",
        "mac"    : "cmd+q",
        "command": "workbench.action.terminal.kill"
      },{
        "key"    : "alt+w",
        "mac"    : "alt+w",
        "command": "workbench.action.terminal.toggleTerminal"
      },{
        "key"    : "alt+e",
        "mac"    : "alt+e",
        "command": "lynx-keymap.checkGitLab"
      },{
        "key"    : "pagedown",
        "mac"    : "pagedown",
        "command": "workbench.action.togglePanel"
      },


      {
        "key"    : "shift+alt+t",
        "mac"    : "shift+alt+t",
        "command": "workbench.action.selectTheme"
      },{
        "key"    : "shift+alt+r",
        "mac"    : "shift+alt+r",
        "command": "workbench.action.reloadWindow"
      },{
        "key"    : "shift+alt+q",
        "mac"    : "shift+alt+q",
        "command": "workbench.action.gotoLine"
      },{
        "key"    : "shift+alt+w",
        "mac"    : "shift+alt+w",
        "command": "expandLineSelection"
      },

      
      {
        "key"    : "alt+j",
        "mac"    : "alt+j",
        "command": "workbench.action.openSettingsJson"
      },{
        "key"    : "ctrl+,",
        "mac"    : "cmd+,",
        "command": ""
      },{
        "key"    : "ctrl+j",
        "mac"    : "cmd+j",
        "command": "workbench.action.openSettings"
      },


      {
        "key"    : "alt+f",
        "mac"    : "alt+f",
        "command": "editor.action.formatDocument"
      },{
        "key"    : "ctrl+alt+f",
        "mac"    : "cmd+alt+f",
        "command": "editor.action.formatSelection.multiple"
      },{
        "key"    : "shift+alt+f",
        "mac"    : "shift+alt+f",
        "command": "editor.action.organizeImports"
      },


      {
        "key"    : "ctrl+/",
        "mac"    : "cmd+/",
        "command": "editor.action.commentLine"
      },{
        "key"    : "alt+/",
        "mac"    : "alt+/",
        "command": "editor.action.blockComment"
      },


      {
        "key"    : "alt+shift+up",
        "mac"    : "alt+shift+up",
        "command": "editor.action.copyLinesUpAction"
      },{
        "key"    : "alt+shift+down",
        "mac"    : "alt+shift+down",
        "command": "editor.action.copyLinesDownAction"
      },{
        "key"    : "ctrl+up",
        "mac"    : "cmd+up",
        "command": "editor.action.insertCursorAbove"
      },{
        "key"    : "ctrl+down",
        "mac"    : "cmd+down",
        "command": "editor.action.insertCursorBelow"
      },


      {
        "key"    : "insert",
        "mac"    : "insert",
        "command": "workbench.action.debug.start"
      },{
        "key"    : "alt+insert",
        "mac"    : "alt+insert",
        "command": "workbench.action.debug.restart"
      },{
        "key"    : "ctrl+insert",
        "mac"    : "cmd+insert",
        "command": "workbench.action.debug.stop"
      },


      {
        "key"    : "end",
        "mac"    : "end",
        "command": "git.viewChanges"
      },{
        "key"    : "pageup",
        "mac"    : "pageup",
        "command": "markdown.showPreviewToSide"
      },

      
      {
        "key"    : "ctrl+backspace",
        "mac"    : "cmd+backspace",
        "command": "deleteWordLeft",
        "when"   : "editorTextFocus"
      },{
        "key"    : "ctrl+alt+backspace",
        "mac"    : "cmd+alt+backspace",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u0001\u000b"},
        "when"   : "terminalFocus"
      },{
        "key"    : "alt+,", 
        "mac"    : "alt+,",
        "command": "workbench.action.terminal.sendSequence",
        "args"   : {"text": "\u001b[C"},
        "when"   : "terminalFocus && !terminalSuggestWidgetVisible"
      },{
        "key"    : "ctrl+delete",
        "mac"    : "cmd+delete",
        "command": "workbench.action.closeFolder"
      },











      {
        "key"    : "alt+shift+audiovolumeup",
        "mac"    : "alt+shift+audiovolumeup",
        "command": "workbench.action.zoomIn",
        "when"   : "editorTextFocus || !inputFocus"
      },{
        "key"    : "alt+shift+audiovolumedown",
        "mac"    : "alt+shift+audiovolumedown",
        "command": "workbench.action.zoomOut",
        "when"   : "editorTextFocus || !inputFocus"
      },











      {
        "key"    : "ctrl+[Backquote]",
        "mac"    : "cmd+[Backquote]",
        "command": "lynx-keymap.toggleTerminalLeft"
      },{
        "key"    : "ctrl+tab",
        "mac"    : "cmd+tab",
        "command": "lynx-keymap.openAndCloseAIChat"
      },{
        "key"    : "shift+escape",
        "mac"    : "shift+escape",
        "command": "workbench.action.toggleMaximizedAuxiliaryBar"
      },

      {
        "key"    : "alt+a",
        "mac"    : "alt+a",
        "command": "lynx-keymap.createNewAISession"
      },      {
        "key"    : "alt+s",
        "mac"    : "alt+s",
        "command": "lynx-keymap.selectModels"
      },{
        "key"    : "alt+d",
        "mac"    : "alt+d",
        "command": "lynx-keymap.selectCode"
      },      


      {
        "key"    : "shift+alt+a",
        "mac"    : "shift+alt+a",
        "command": "lynx-keymap.toggleAgentMode"
      },{
        "key"    : "shift+alt+s",
        "mac"    : "shift+alt+s",
        "command": "lynx-keymap.showAIHistory"
      },


      {
        "key"    : "ctrl+enter",
        "mac"    : "cmd+return",
        "command": "-github.copilot.generate"
      },{
        "key"    : "alt+enter",
        "mac"    : "alt+return",
        "command": "inlineChat.close",
        "when"   : "inlineChatFocused"
      }
    ]
  },

  "commands": [
      {
        "command": "lynx-keymap.toggleTerminalLeft",
        "title"  : "Toggle Terminal Left"
      },
      {
        "command": "lynx-keymap.generateAICommit",
        "title"  : "Generate AI Commit Message"
      },
      {
        "command": "lynx-keymap.selectCode",
        "title"  : "AI Select Code"
      },{
        "command": "lynx-keymap.openAndCloseAIChat",
        "title"  : "Open and Close AI Chat"
      },{
        "command": "lynx-keymap.createNewAISession",
        "title"  : "Create New AI Session"
      },{
        "command": "lynx-keymap.showAIHistory",
        "title"  : "Show AI Chat History"
      },{
        "command": "lynx-keymap.selectModels",
        "title"  : "Select AI Model"
      },

      {
        "command": "lynx-keymap.toggleAgentMode",
        "title"  : "Toggle AI Agent Mode"
      },

      {
      "command": "lynx-keymap.checkF1QuickSwitch",
      "title"  : "Check F1-QuickSwitch Extension and Execute"
      },{
      "command": "lynx-keymap.checkGitLab",
      "title"  : "Check GitLab Extension and Execute"
      },{
      "command": "lynx-keymap.checkCompareCode",
      "title"  : "Check Compare Code Extension and Execute"
      }
    ],
    "devDependencies": {
      "@eslint/js": "^9.21.0",
      "@types/node": "^25.6.0",
      "@types/vscode": "^1.116.0",
      "esbuild": "^0.25.0",
      "eslint": "^9.21.0",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.25.0"
    }
}
